<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FocusBot.App.Views.Controls.FocusStatusControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d"
    automation:AutomationProperties.Name="Current foreground window">

    <Grid>
        <!-- Window info (compact single line) -->
        <TextBlock
                   Style="{StaticResource FbWindowInfoTextStyle}"
                   MaxLines="1"
                   Margin="0,0,0,2"
                   Text="{x:Bind ViewModel.DisplayWindowCaption, Mode=OneWay}"/>
    </Grid>
</UserControl>
