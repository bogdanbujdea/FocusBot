<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FocusBot.App.Views.NewSession"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:converters="using:FocusBot.App.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="{StaticResource FbCardBackgroundBrush}"
            BorderBrush="{StaticResource FbCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource FbCornerRadiusMedium}"
            Padding="16">
        <StackPanel Spacing="16">
            <TextBlock Text="Start session"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>

            <TextBlock Text="Title"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>
            <TextBox Text="{x:Bind ViewModel.SessionTitle, Mode=TwoWay}"
                     PlaceholderText="Session title"
                     CornerRadius="{StaticResource FbCornerRadiusSmall}"
                     IsEnabled="{x:Bind ViewModel.State.IsBusy, Converter={StaticResource InverseBoolConverter}, Mode=OneWay}"
                     automation:AutomationProperties.Name="Session title"/>

            <TextBlock Text="Context"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>
            <TextBox Text="{x:Bind ViewModel.SessionContext, Mode=TwoWay}"
                     PlaceholderText="Optional context"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="120"
                     CornerRadius="{StaticResource FbCornerRadiusSmall}"
                     IsEnabled="{x:Bind ViewModel.State.IsBusy, Converter={StaticResource InverseBoolConverter}, Mode=OneWay}"
                     automation:AutomationProperties.Name="Session context"/>

            <Button Content="Start"
                    Style="{StaticResource FbAccentButtonStyle}"
                    Command="{x:Bind ViewModel.StartCommand, Mode=OneWay}"
                    HorizontalAlignment="Left"
                    automation:AutomationProperties.Name="Start session"/>

            <InfoBar IsOpen="{x:Bind ViewModel.State.ErrorMessage, Converter={StaticResource StringToBoolConverter}, Mode=OneWay}"
                     Severity="Error"
                     Title="Error"
                     Message="{x:Bind ViewModel.State.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"
                     Closed="InfoBar_Closed"/>
        </StackPanel>
    </Border>
</UserControl>
