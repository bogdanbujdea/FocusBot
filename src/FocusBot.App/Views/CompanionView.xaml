<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FocusBot.App.Views.CompanionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource FbPageBackgroundBrush}">

    <Grid Margin="32,40,32,32" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
        <StackPanel Spacing="20">
            <TextBlock Text="Companion Mode"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource FbTextSecondaryBrush}"
                       HorizontalAlignment="Center"/>

            <TextBlock FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource FbTextPrimaryBrush}">
                <Run Text="Following: "/><Run Text="{x:Bind ViewModel.TaskName, Mode=OneWay}" FontWeight="Normal"/>
            </TextBlock>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Border x:Name="StatusBadge"
                                CornerRadius="12" Padding="10,4"
                                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                            <TextBlock Text="{x:Bind ViewModel.StatusBadgeText, Mode=OneWay}"
                                       FontWeight="SemiBold" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.Reason, Mode=OneWay}"
                               FontSize="13"
                               Foreground="{StaticResource FbTextSecondaryBrush}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <TextBlock Text="{x:Bind ViewModel.ContextDisplay, Mode=OneWay}"
                               FontSize="13"
                               Foreground="{StaticResource FbTextSecondaryBrush}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="{x:Bind ViewModel.FocusScoreDisplay, Mode=OneWay}"
                               FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button Content="Disconnect"
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.DisconnectCommand}"/>
        </StackPanel>
    </Grid>
</Page>
