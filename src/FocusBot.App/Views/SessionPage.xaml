<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FocusBot.App.Views.SessionPage"
    x:Name="SessionPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:FocusBot.App.Views"
    xmlns:converters="using:FocusBot.App.Converters"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d"
    Background="{StaticResource FbPageBackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BoolToVisibilityInvertedConverter x:Key="BoolToVisibilityInverted"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="32,16,32,0"
                    Visibility="{x:Bind ViewModel.IsExtensionConnected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center"/>
            <TextBlock Text="Extension connected" Margin="8,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32" Spacing="24">
                <views:ActiveSession DataContext="{x:Bind ViewModel.ActiveSession, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.HasActiveSession, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                <views:NewSession DataContext="{x:Bind ViewModel.NewSession, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.HasActiveSession, Mode=OneWay, Converter={StaticResource BoolToVisibilityInverted}}"/>

                <Button Content="Settings"
                        Style="{StaticResource FbOutlineButtonStyle}"
                        Command="{x:Bind ViewModel.OpenSettingsCommand}"
                        HorizontalAlignment="Left"
                        automation:AutomationProperties.Name="Open settings"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
