<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="FocusBot.App.Views.HowItWorksDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="How Foqus Bot works"
    PrimaryButtonText="Got it"
    SecondaryButtonText="Open Settings"
    DefaultButton="Primary"
    Background="{StaticResource FbCardBackgroundBrush}"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    automation:AutomationProperties.Name="How Foqus Bot works">

    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="What Foqus Bot does"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>
            <TextBlock Foreground="{StaticResource FbTextPrimaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="22">
                <Run Text="Start a focus session and Foqus monitors your active app and window context in real time. AI classifies whether you're aligned with your task and updates a live Focus Score (0-100%). When you end the session, your results are available across your signed-in Foqus clients."/>
            </TextBlock>

            <Border Style="{StaticResource FbDividerStyle}" Margin="0,4,0,0"/>

            <TextBlock Text="Your data storage"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>
            <TextBlock Foreground="{StaticResource FbTextPrimaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="22">
                <Run Text="Foqus stores your focus sessions and analytics in your cloud account so your progress syncs across devices. Based on user feedback, we may introduce a local-only option in the future."/>
            </TextBlock>

            <Border Style="{StaticResource FbDividerStyle}" Margin="0,4,0,0"/>

            <TextBlock Text="Trial and pricing"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>
            <TextBlock Foreground="{StaticResource FbTextPrimaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="22">
                <Run Text="New accounts start with 24 hours of full access. Foqus relies on AI tokens and cloud infrastructure, so we cannot sustainably offer a fully free tier. After the trial, choose a plan on the billing page to continue."/>
            </TextBlock>

            <Border Style="{StaticResource FbDividerStyle}" Margin="0,4,0,0"/>

            <TextBlock Text="BYOK discount and AI provider"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>
            <TextBlock Foreground="{StaticResource FbTextPrimaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="22">
                <Run Text="You can lower your subscription cost with Foqus BYOK by using your own OpenAI API key. We use OpenAI because their lower-cost models perform very well for focus-alignment classification. If you choose BYOK, your key is encrypted on your device and used only for classification requests."/>
            </TextBlock>

            <Border Style="{StaticResource FbDividerStyle}" Margin="0,4,0,0"/>

            <TextBlock Text="Browser extension"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="14"/>
            <TextBlock Foreground="{StaticResource FbTextPrimaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="22">
                <Run Text="For the best web-page focus accuracy, install the Foqus browser extension for Chrome or Edge. The desktop app cannot directly read the URL of pages open in your browser, so the extension provides page context that improves classification quality."/>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <HyperlinkButton x:Name="ExtensionStoreEdgeLink"
                                 Content="Get it for Edge"
                                 automation:AutomationProperties.Name="Get extension for Edge"/>
                <HyperlinkButton x:Name="ExtensionStoreChromeLink"
                                 Content="Get it for Chrome"
                                 automation:AutomationProperties.Name="Get extension for Chrome"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
