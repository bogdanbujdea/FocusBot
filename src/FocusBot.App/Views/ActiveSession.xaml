<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FocusBot.App.Views.ActiveSession"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:FocusBot.App.Converters"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
    </UserControl.Resources>

    <Border Background="{StaticResource FbCardBackgroundBrush}"
            BorderBrush="{StaticResource FbCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource FbCornerRadiusMedium}"
            Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Active session"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="12"
                       Opacity="0.7"/>

            <TextBlock Text="{Binding SessionTitle, Mode=OneWay}"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       automation:AutomationProperties.Name="Session title"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Started"
                           Opacity="0.6"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StartedAtUtc, Mode=OneWay}"
                           VerticalAlignment="Center"
                           automation:AutomationProperties.Name="Session start time"/>
                <TextBlock Text="Paused"
                           Opacity="0.6"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsPaused, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <TextBlock Text="{Binding ElapsedDisplay, Mode=OneWay}"
                       FontSize="48"
                       FontWeight="Bold"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,16"
                       Opacity="1"
                       automation:AutomationProperties.Name="Elapsed time"/>

            <TextBlock Text="{Binding ClassificationLabel, Mode=OneWay}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       Visibility="{Binding HasClassification, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                       automation:AutomationProperties.Name="Classification status"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Content="{Binding PauseResumeLabel, Mode=OneWay}"
                        Style="{StaticResource FbAccentButtonStyle}"
                        Command="{Binding PauseOrResumeCommand}"
                        IsEnabled="{Binding State.IsBusy, Converter={StaticResource InverseBoolConverter}, Mode=OneWay}"
                        automation:AutomationProperties.Name="Pause or resume"/>

                <Button Content="Stop"
                        Style="{StaticResource FbCardActionDeleteStyle}"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding State.IsBusy, Converter={StaticResource InverseBoolConverter}, Mode=OneWay}"
                        automation:AutomationProperties.Name="Stop session"/>
            </StackPanel>

            <InfoBar IsOpen="{Binding State.ErrorMessage, Converter={StaticResource StringToBoolConverter}, Mode=OneWay}"
                     Severity="Error"
                     Title="Error"
                     Message="{Binding State.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"
                     Closed="InfoBar_Closed"/>
        </StackPanel>
    </Border>
</UserControl>
