<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FocusBot.App.Views.ActiveSession"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:FocusBot.App.Converters"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Border Background="{StaticResource FbCardBackgroundBrush}"
            BorderBrush="{StaticResource FbCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource FbCornerRadiusMedium}"
            Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Active session"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="12"
                       Opacity="0.7"/>

            <TextBlock Text="{x:Bind ViewModel.SessionTitle, Mode=OneWay}"
                       Style="{StaticResource FbColumnHeaderStyle}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       automation:AutomationProperties.Name="Session title"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Started"
                           Opacity="0.6"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind FormatStartTime(ViewModel.StartedAtUtc), Mode=OneWay}"
                           VerticalAlignment="Center"
                           automation:AutomationProperties.Name="Session start time"/>
                <TextBlock Text="Paused"
                           Opacity="0.6"
                           VerticalAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsPaused, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.ElapsedDisplay, Mode=OneWay}"
                       FontSize="48"
                       FontWeight="Bold"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,16"
                       Opacity="{x:Bind TimerOpacity(ViewModel.IsPaused), Mode=OneWay}"
                       automation:AutomationProperties.Name="Elapsed time"/>
        </StackPanel>
    </Border>
</UserControl>
