{
  "manifest_version": 3,
  "name": "FocusBot Companion",
  "version": "1.0.0",
  "description": "Browser companion for FocusBot — provides accurate browser context and shows focus status overlay",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:51789/*",
    "http://127.0.0.1:51789/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "FocusBot Companion"
  },
  "incognito": "not_allowed"
}
